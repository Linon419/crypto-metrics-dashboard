# 生产环境配置示例
# 复制此文件为 .env.production 并填入真实值

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_SYSTEM_PROMPT=你是一个数据清洗专家，请将加密货币指标数据转换为结构化JSON格式。

# Database Configuration
DB_STORAGE=/data/db/database.sqlite

# JWT Configuration
JWT_SECRET=your-very-secure-jwt-secret-key-change-this

# API Configuration
API_PUBLIC_HOST=http://your-server-ip:3080

# 使用方法：
# 1. 复制此文件为 .env.production
# 2. 填入真实的配置值
# 3. 在docker-compose.prod.yml中使用 env_file: .env.production
