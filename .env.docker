# Docker Compose 环境变量示例（请自行替换为真实值）

# 生产环境必须：强随机密钥（长度>=32）
JWT_SECRET=please_generate_a_strong_secret_at_least_32_chars

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# 数据库（SQLite 文件路径）
DB_STORAGE=/data/db/database.sqlite

# 前端运行时 API 地址（用于 /app-config.js）
API_PUBLIC_HOST=http://localhost:3080

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_IDS=123456789,987654321
API_BASE_URL=http://localhost:3001/api

# MCP Gateway（公网/局域网部署时必须设置）
MCP_GATEWAY_TOKEN=please_set_a_strong_gateway_token
# MCP Gateway 转发到后端 API（可选，默认 http://127.0.0.1:${PORT}/api）
# CRYPTO_API_BASE_URL=http://127.0.0.1:3001/api

# 时区
TZ=Asia/Shanghai
