# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Configuration
API_BASE_URL=http://localhost:3001/api

# Admin Configuration (comma-separated chat IDs for admin access)
ADMIN_CHAT_IDS=123456789,987654321

# Database Configuration (optional, defaults to ./data/bot_data.db)
# DB_PATH=./data/bot_data.db

# Encryption Key for storing user credentials (optional, auto-generated if not provided)
# ENCRYPTION_KEY=your_32_char_encryption_key_here

# Timezone for notifications (optional, defaults to Asia/Shanghai)
# TZ=Asia/Shanghai