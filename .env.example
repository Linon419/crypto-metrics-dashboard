# Local shared configuration for development and one-click launchers.
# Copy this file to `.env`, then fill in the values you need.

# Server
PORT=3001
API_PUBLIC_HOST=http://localhost:3001
DB_STORAGE=./database.sqlite
JWT_SECRET=local-one-click-dashboard-secret-change-me-2026

# First local admin account. Used only when the database has no admin user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# AI parsing. Leave OPENAI_API_KEY empty if you only need to view existing data.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Telegram Bot, optional.
# TELEGRAM_BOT_TOKEN=
# API_BASE_URL=http://localhost:3001/api
# ADMIN_CHAT_IDS=

# MCP Gateway, optional for local use.
# MCP_GATEWAY_TOKEN=
